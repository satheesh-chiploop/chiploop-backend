{
  "model_profile_id": "customer_byok_openai_example",
  "provider": "openai",
  "ai_billing_mode": "byok",
  "model_key_owner": "customer",
  "routing": {
    "default": {
      "model": "gpt-5.5",
      "stream": true
    },
    "rtl_generation": {
      "model": "gpt-5.5",
      "max_completion_tokens": 32000,
      "timeout_sec": 360,
      "stream": true
    }
  },
  "env": {
    "OPENAI_API_KEY": "set-in-secret-manager"
  }
}
